{
  "name": "nuxt-frigear-nu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "lint": "eslint .",
    "lint:md": "npx mdclint 'content/**/*.md'",
    "clean": "rm -rf pnpm-lock.yaml node_modules .nuxt ",
    "prepare": "nuxt prepare",
    "cf:deploy": "npx wrangler --cwd .output/ deploy",
    "cf:deploy-staging": "npx wrangler --env staging --cwd .output/ deploy",
    "db": "npx nuxt db",
    "db:generate": "npx nuxt db generate",
    "db:migrate": "npx nuxt db migrate",
    "db:drop-all": "npx nuxt db drop-all",
    "db:reset": "pnpm run db:drop-all && pnpm run db:migrate",
    "test:nuxt": "npx vitest --project nuxt",
    "test:unit": "npx vitest --project unit",
    "test:watch": "npx vitest --watch",
    "test": "npx vitest"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@nitrotool/errors": "^1.0.4",
    "@nitrotool/jwt": "^1.0.4",
    "@nuxthub/core": "^0.10.6",
    "@nuxtjs/device": "4.0.0",
    "@nuxtjs/i18n": "^10.2.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pinia/colada": "^1.0.0",
    "@pinia/colada-nuxt": "0.3.1",
    "@pinia/nuxt": "^0.11.3",
    "@unlok-co/nuxt-stripe": "6.0.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue-email/components": "^0.0.21",
    "@vue-email/render": "^0.0.9",
    "consola": "^3.4.2",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "escape-html": "^1.0.3",
    "h3-zod": "^0.5.3",
    "minimatch": "^10.1.1",
    "nuxt": "^4.3.0",
    "nuxt-auth-utils": "0.5.28",
    "nuxt-studio": "^1.3.1",
    "nuxt-zod-i18n": "1.12.1",
    "simple-content-site": "https://pkg.pr.new/simple-content-site@46",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/eslint-config": "^1.12.1",
    "@nuxt/kit": "^4.3.1",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/escape-html": "^1.0.4",
    "@vue/compiler-sfc": "^3.5.27",
    "@vue/test-utils": "^2.4.6",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.39.2",
    "happy-dom": "^20.8.3",
    "nuxt-component-meta": "^0.17.2",
    "nuxt-resend": "^0.0.2",
    "playwright-core": "^1.58.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.2",
    "wrangler": "^4.59.2"
  },
  "peerDependencies": {
    "h3": "1.15.5"
  },
  "packageManager": "pnpm@10.19.0"
}